        if (!answers[key]) return null;
        const raw = answers[key].values ? answers[key].values[0] : (Array.isArray(answers[key]) ? answers[key][0] : answers[key]);
        return parseCurrencyNumber(raw);
    }

    // Compute loan amount and user LTV and monthly rental income from the form
    // Returns { loanAmount: number|null, purchasePrice: number|null, propertyValue: number|null, userLtv: number|null, monthlyRental: number|null }
    function computeUserLoanAndLtv() {
        const purchase = answerFirstNumeric('currency-3');      // purchase price
        const deposit = answerFirstNumeric('currency-4');       // deposit
        const outstanding = answerFirstNumeric('currency-5');   // outstanding mortgage
        const additional = answerFirstNumeric('currency-17');   // additional finance requested
        const propValue = answerFirstNumeric('currency-18');    // property value (for remortgage)
        const monthlyRental = answerFirstNumeric('currency-6'); // monthly rental income

        let loanAmount = null;
        if (purchase !== null && deposit !== null) {
            loanAmount = purchase - deposit;
        } else if (outstanding !== null) {
            loanAmount = outstanding + (additional || 0);
        } else if (additional !== null && propValue !== null) {
            loanAmount = additional;
        }

        let denom = null;
        if (purchase !== null) denom = purchase;
        else if (propValue !== null) denom = propValue;

        let userLtv = null;
        if (loanAmount !== null && denom !== null && denom > 0) {
            userLtv = (loanAmount / denom) * 100;
            userLtv = Math.round(userLtv * 100) / 100;
        }

        return {
            loanAmount: (loanAmount !== null && !isNaN(loanAmount)) ? loanAmount : null,
            purchasePrice: (purchase !== null && !isNaN(purchase)) ? purchase : null,
            propertyValue: (propValue !== null && !isNaN(propValue)) ? propValue : null,
            userLtv: (userLtv !== null && !isNaN(userLtv)) ? userLtv : null,
            monthlyRental: (monthlyRental !== null && !isNaN(monthlyRental)) ? monthlyRental : null
        };
    }

