    // ---------- REPLACED: ensureCF7ReadyInProgress (improved re-init + unhide logic) ----------
    function ensureCF7ReadyInProgress() {
        const progress = document.getElementById('progress-form-container');
        if (!progress) return;

        // Helper to make a node visible and remove hiding attributes/styles
        function unhideNode(node) {
            try {
                if (!node || node.nodeType !== 1) return;
                // Remove inline display:none and aria-hidden
                if (node.style && node.style.display && node.style.display.toLowerCase() === 'none') {
                    node.style.removeProperty('display');
                }
                if (node.hasAttribute && node.hasAttribute('aria-hidden')) node.removeAttribute('aria-hidden');
                // Ensure visibility
                try { node.style.visibility = node.style.visibility || 'visible'; } catch (e) {}
            } catch (e) {}
        }

        // Try to find an existing CF7 form already inside the progress container
        const existingForm = progress.querySelector('form.wpcf7-form, .wpcf7, form');
        if (existingForm) {
            // Ensure it's visible and re-init
            unhideNode(existingForm);
            unhideNode(existingForm.parentNode);
            try {
                if (window.wpcf7 && typeof wpcf7.initForm === 'function') {
                    try { wpcf7.initForm(existingForm); } catch (e) { console.warn('wpcf7.initForm failed', e); }
                } else {
                    try { document.dispatchEvent(new Event('wpcf7init')); } catch (e) {}
                }
                try { document.dispatchEvent(new Event('wpcf7open')); } catch (e) {}
            } catch (e) {
                console.warn('CF7 re-init attempt error', e);
            }
            return;
        }

        // Otherwise move any CF7 nodes into progress and init them
        const moved = (function moveAnyCF7() {
            let movedAny = false;
            const candidates = document.querySelectorAll('.wpcf7, .wpcf7-form, form.wpcf7-form, form');
            candidates.forEach(f => {
                if (!f || progress.contains(f)) return;
                try {
                    // Move node into progress container
                    f.parentNode && progress.appendChild(f);
                    movedAny = true;
                    // Unhide moved node and its parents
                    unhideNode(f);
                    unhideNode(f.parentNode);
                } catch (e) {
                    console.warn('Failed to move CF7 node into progress container', e);
                }
            });
            return movedAny;
        })();

        // After moving, attempt to init and ensure visible. Use a short retry loop to handle timing.
        const tryInit = () => {
            const form = progress.querySelector('form.wpcf7-form, .wpcf7, form');
            if (!form) return false;
            try {
                // Remove any inline hiding on the form and its wrapper chain
                let node = form;
                for (let i = 0; i < 6 && node; i++, node = node.parentNode) {
                    unhideNode(node);
                }

                // Re-init CF7 if available
                if (window.wpcf7 && typeof wpcf7.initForm === 'function') {
                    try { wpcf7.initForm(form); } catch (e) { console.warn('wpcf7.initForm failed', e); }
                } else {
                    try { document.dispatchEvent(new Event('wpcf7init')); } catch (e) {}
                }

                // Dispatch open event so any listeners update visibility
                try { document.dispatchEvent(new Event('wpcf7open')); } catch (e) {}

                // Ensure the form is focusable and visible
                try { form.setAttribute('tabindex', '-1'); form.focus(); } catch (e) {}

                return true;
            } catch (e) {
                return false;
            }
        };

        // Try immediately, then retry a few times with small delays to handle race conditions
        if (tryInit()) return;
        let attempts = 0;
        const maxAttempts = 8;
        const interval = setInterval(() => {
            attempts++;
            if (tryInit() || attempts >= maxAttempts) {
                clearInterval(interval);
            }
        }, 80);
    }

