    // Observe CF7 presence but do not move on initial load. Moving happens on demand.
    (function observeAndMoveCF7() {
        const progress = document.getElementById('progress-form-container');
        if (!progress) return;

        const findCF7Candidates = (node) => {
            const candidates = [];
            if (!node) return candidates;
            if (node.nodeType === 1) {
                if (node.matches && (node.matches('.wpcf7') || node.matches('.wpcf7-form') || (node.tagName && node.tagName.toLowerCase()==='form' && node.classList.contains('wpcf7-form')))) {
                    candidates.push(node);
                }
                const found = node.querySelectorAll ? node.querySelectorAll('.wpcf7, .wpcf7-form, form.wpcf7-form, form') : [];
                Array.prototype.forEach.call(found, f => candidates.push(f));
            }
            return candidates;
        };

        // Do NOT move CF7 on initial load. Only observe and mark detection.
        try {
            const bodyObserver = new MutationObserver((mutations) => {
                for (const m of mutations) {
                    if (m.addedNodes && m.addedNodes.length) {
                        m.addedNodes.forEach(n => {
                            const cands = findCF7Candidates(n);
                            if (cands.length) {
                                // CF7 markup appeared somewhere — mark detection for on-demand move
                                window._funder_cf7_detected = true;
                            }
                        });
                    }
                    if (m.type === 'attributes' && (m.attributeName === 'style' || m.attributeName === 'class')) {
                        const cands = findCF7Candidates(m.target);
                        if (cands.length) window._funder_cf7_detected = true;
                    }
                }
            });
            bodyObserver.observe(document.body, { childList: true, subtree: true, attributes: true, attributeFilter: ['style', 'class'] });
        } catch (e) {
            // fallback: set a flag so ensureCF7ReadyInProgress will still attempt a move when needed
            window._funder_cf7_detected = true;
        }
    })();

    // Move CF7 into progress container and init it on demand (do not run automatically on every mutation)
    function moveCF7IntoProgressContainerNow() {
        const progress = document.getElementById('progress-form-container');
        if (!progress) return false;
        let movedAny = false;

        // Find any CF7 form nodes that are not already inside the progress container
        const candidates = document.querySelectorAll('.wpcf7, .wpcf7-form, form.wpcf7-form, form');
        candidates.forEach(f => {
            if (!f || progress.contains(f)) return;
            try {
                // Move the node (do not clone)
                f.parentNode && progress.appendChild(f);
                movedAny = true;

                // Re-init CF7 on the moved form if available
                try {
                    if (window.wpcf7 && typeof wpcf7.initForm === 'function') {
                        try { wpcf7.initForm(f); } catch (e) { console.warn('wpcf7.initForm failed', e); }
                    } else {
