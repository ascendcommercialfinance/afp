    // Poll helper used when showing progress to catch CF7 quickly
    function pollForCF7AndShowButton({ interval = 30, timeout = 900 } = {}) {
        const btn = document.getElementById('back-to-results-btn');
        if (!btn) return;
        const start = Date.now();

        // immediate quick check
        if (isCF7Visible() || isProgressVisible()) {
            btn.style.display = 'block';
            return;
        }

        const t = setInterval(() => {
            if (window._funderIntentionalHide) {
                // if intentionally hidden, don't show yet
                if (Date.now() - start > timeout) clearInterval(t);
                return;
            }
            if (isCF7Visible() || isProgressVisible()) {
                btn.style.display = 'block';
                clearInterval(t);
                return;
            }
            if (Date.now() - start > timeout) {
                clearInterval(t);
                // fallback: if progress container is visible, show button anyway
                if (isProgressVisible()) btn.style.display = 'block';
            }
        }, interval);
    }

