    // ---------- Helpers for numeric parsing and LTV/serviceability ----------

    // Parse a currency/number string into a float (handles "£", commas, "k", etc.)
    function parseCurrencyNumber(s) {
        if (s === undefined || s === null) return null;
        let str = String(s).trim().toLowerCase();
        if (!str) return null;
        str = str.replace(/£/g, '').replace(/,/g, '').replace(/\s+/g, '');
        if (str === '') return null;
        if (str.endsWith('k')) {
            const n = parseFloat(str.replace(/k$/, ''));
            return isNaN(n) ? null : n * 1000;
        }
        const n = parseFloat(str.replace(/[^0-9.\-]/g, ''));
        return isNaN(n) ? null : n;
    }

    // Read a single value from persisted form answers (handles arrays/objects)
