    // ---------- Enhanced filtering with LTV and serviceability ----------

    function getActiveFilters() {
        const active = {};
        document.querySelectorAll(".btl-toggle.active").forEach(btn => {
            const key = btn.dataset.toggle;
            const value = btn.dataset.value;
            if (!active[key]) active[key] = [];
            active[key].push(String(value).toLowerCase());
        });
        if (active.zero_fee && active.zero_fee.length) active.zero_fee = true;
        return active;
    }

    function normaliseRateType(rt) {
        rt = String(rt || '').toLowerCase();
        if (rt.includes('fix') || rt.includes('fixed')) return 'fixed';
        if (rt.includes('track') || rt.includes('tracker')) return 'tracker';
        if (rt.includes('discount')) return 'variable';
        if (rt.includes('var') || rt.includes('variable') || rt.includes('svr')) return 'variable';
        return rt;
    }

    function parseFeeNumeric(feeRaw) {
        if (feeRaw === undefined || feeRaw === null) return null;
        const s = String(feeRaw).trim().toLowerCase();
        if (s === '' || s === 'n/a' || s === 'none') return null;
        if (s.includes('free') || s.includes('zero') || s === '0' || s === '£0' || s.includes('no fee')) return 0;
        const cleaned = s.replace(/[^0-9.\-]/g, '');
        if (cleaned === '' || cleaned === '.' || cleaned === '-') return null;
        const n = parseFloat(cleaned);
        return isNaN(n) ? null : n;
    }

    function getFilteredResults(filters, sortValue) {
        const src = Array.isArray(fullResults) ? fullResults.slice() : [];
        let results = src.filter(item => !!item);

        // RATE TYPE (explicit column)
        if (filters.rate_type?.length) {
            results = results.filter(item => {
                const rt = String(item.rate_type || item.loan_type || '').toLowerCase();
                if (filters.rate_type.includes('fixed')) return rt === 'fixed' || rt.includes('fixed');
                if (filters.rate_type.includes('variable')) return rt === 'variable' || rt.includes('track') || rt.includes('tracker') || rt.includes('svr') || rt.includes('discount');
                return true;
            });
        }

        // ZERO FEE (explicit column or parsed fee)
        if (filters.zero_fee) {
            results = results.filter(item => {
                const z = String(item.zero_fee || item.zero_fee_flag || '').toLowerCase();
                if (z === '1' || z === 'yes' || z === 'true') return true;
                const fee = parseFeeNumeric(item.product_fee ?? item.fee ?? '');
                return fee === 0;
            });
        }

        // PROPERTY TYPE (explicit accepts_* columns)
        if (filters.prop_type?.length) {
            results = results.filter(item => {
                const p = String(item.prop_type || '').toLowerCase();
                return filters.prop_type.every(req => {
                    if (req === 'hmo') return p === 'hmo' || String(item.accepts_hmo || '').toLowerCase() === 'yes';
                    if (req === 'mufb') return p === 'mufb' || String(item.accepts_mufb || '').toLowerCase() === 'yes';
                    if (req === 'holiday') return p === 'holiday' || String(item.accepts_holiday || item.accepts_hol || '').toLowerCase() === 'yes';
                    if (req === 'standard') return p === 'standard' || p === '';
                    return true;
                });
            });
        }

        // PRODUCT TERM (explicit product_term or max_term)
        if (filters.product_term?.length) {
            results = results.filter(item => {
                const term = String(item.product_term || item.product_term_display || item.max_term || '').toLowerCase();
                return filters.product_term.some(req => String(term).includes(String(req).toLowerCase()));
            });
        }

        // ---------- Loan / LTV / min/max loan checks and serviceability ----------

        const user = computeUserLoanAndLtv();

        results = results.filter(item => {
            // min_loan / max_loan enforcement
            const minLoan = parseCurrencyNumber(item.min_loan ?? item.min_loan_value ?? item.min_loan_display) ?? null;
            const maxLoan = parseCurrencyNumber(item.max_loan ?? item.max_loan_value ?? item.max_loan_display) ?? null;

            if (user.loanAmount !== null) {
                if (minLoan !== null && user.loanAmount < minLoan) return false;
                if (maxLoan !== null && user.loanAmount > maxLoan) return false;
            }

            // LTV enforcement
            const prodMaxLtv = parseFloat(String(item.max_ltv ?? '').replace(/[^0-9.\-]/g, ''));
            if (!isNaN(prodMaxLtv) && user.userLtv !== null) {
                if (user.userLtv > prodMaxLtv) return false;
            }

            // Serviceability check (use min_serviceability/min_serviceability_rate for eligibility)
            if (user.monthlyRental !== null) {
                const annualRate = parseProductRate(item); // note: parseProductRate still prefers min_serviceability_rate for eligibility
                const svcMultiplierRaw = item.min_serviceability ?? item.min_serviceability_value ?? item.min_serviceability_display;
                const svcMultiplier = svcMultiplierRaw !== undefined && svcMultiplierRaw !== null && String(svcMultiplierRaw).trim() !== '' ? parseFloat(String(svcMultiplierRaw).replace(/[^0-9.\-]/g, '')) : null;

                if (annualRate !== null && svcMultiplier !== null && user.loanAmount !== null) {
                    const monthlyInterest = (user.loanAmount * (annualRate / 100)) / 12;
                    const requiredIncome = monthlyInterest * svcMultiplier;
                    if (user.monthlyRental <= requiredIncome) return false;
                }
            }

            return true;
        });

        // ---------- Sorting (unchanged) ----------
        if (sortValue === 'rate') {
            results.sort((a, b) => parseFloat(String(a.rates_from || '').replace(/[^\d\.]/g, '') || 0) - parseFloat(String(b.rates_from || '').replace(/[^\d\.]/g, '') || 0));
        } else if (sortValue === 'annual_cost') {
            results.sort((a, b) => (a.total_cost || 0) - (b.total_cost || 0));
        } else if (sortValue === 'ltv') {
            results.sort((a, b) => parseFloat(b.max_ltv || 0) - parseFloat(a.max_ltv || 0));
        }

        return results;
    }

    // Debounced, guarded applyFiltersAndSort with console checks included
    function applyFiltersAndSort() {
        // reset pagination whenever filters/sort change
        resultsOffset = 0;

        if (window._applyFiltersTimer) clearTimeout(window._applyFiltersTimer);
        window._applyFiltersTimer = setTimeout(() => {
            if (window._applyingFilters) return;
            window._applyingFilters = true;

            try {
                const filters = getActiveFilters();
                const sortDropdownEl = document.getElementById("btl-sort");
                const sortValue = sortDropdownEl ? sortDropdownEl.value : "rate"; // default to lowest rate first

                const hasFilters = Object.keys(filters).length > 0 && (
                    (filters.rate_type && filters.rate_type.length) ||
                    filters.zero_fee ||
                    (filters.prop_type && filters.prop_type.length) ||
                    (filters.product_term && filters.product_term.length)
                );

                // If no client filters, show server eligibleResults (server list authoritative for eligibility)
                if (!hasFilters) {
                    const base = Array.isArray(eligibleResults) ? eligibleResults.slice() : [];
                    if (sortValue === "rate") {
                        base.sort((a, b) => parseFloat(String(a.rates_from || '').replace(/[^\d\.]/g, '') || 0) - parseFloat(String(b.rates_from || '').replace(/[^\d\.]/g, '') || 0));
                    } else if (sortValue === "annual_cost") {
                        base.sort((a, b) => (a.total_cost || 0) - (b.total_cost || 0));
                    } else if (sortValue === "ltv") {
                        base.sort((a, b) => parseFloat(b.max_ltv || 0) - parseFloat(a.max_ltv || 0));
                    }
                    console.log('CONSOLE CHECK', { fullCount: fullResults.length, eligibleCount: eligibleResults.length, showingServerEligible: base.length });
                    renderResultsList(base, base);
                    return;
                }

                // Client filters active: filter fullResults (sheet is authoritative for display)
                let filtered = getFilteredResults(filters, sortValue);

                // Instead of removing sheet rows by intersecting with eligibleResults,
                // mark server eligibility by matching_id so sheet rows remain visible.
                if (Array.isArray(eligibleResults) && eligibleResults.length) {
                    const eligibleIds = new Set(eligibleResults.map(e => String(e.matching_id || '').trim()).filter(Boolean));
                    filtered.forEach(f => {
                        f._serverEligible = eligibleIds.has(String(f.matching_id || '').trim());
                    });

                    // Log a sample of items that are not server-eligible (for debugging)
                    const dropped = filtered.filter(f => !eligibleIds.has(String(f.matching_id || '').trim()));
                    if (dropped.length) {
                        console.log('CONSOLE CHECK: items that are not server-eligible (sample)', dropped.slice(0,8));
                    }
                }

                console.log('CONSOLE CHECK', { filters, filteredCount: filtered.length, eligibleCount: (eligibleResults||[]).length, sampleFiltered: filtered.slice(0,8) });

                // Render using the full filtered list; renderResultsList will dedupe by matching_id and slice to pages
                renderResultsList(filtered, filtered);
            } finally {
                window._applyingFilters = false;
            }
        }, 120);
    }

    function wireFilterControls() {
        document.querySelectorAll(".btl-toggle").forEach(btn => {
            if (btn.dataset._wired === "1") return;
            btn.dataset._wired = "1";
            btn.addEventListener("click", () => {
                const isActive = btn.classList.toggle("active");
                btn.style.background = isActive ? "#149580" : "#fff";
                btn.style.color = isActive ? "white" : "#333";
                btn.style.borderColor = isActive ? "#149580" : "#ccc";
                applyFiltersAndSort();
            });
        });

        const sortDropdownEl = document.getElementById("btl-sort");
        if (sortDropdownEl && !sortDropdownEl.dataset._wired) {
            sortDropdownEl.dataset._wired = "1";
            sortDropdownEl.addEventListener("change", () => applyFiltersAndSort());
        }

        const clearFilters = document.getElementById("clear-filters");
        const filterBtn = document.getElementById("toggle-filters");
        const filterBox = document.getElementById("filters-container");

        if (clearFilters && !clearFilters.dataset._wired) {
            clearFilters.dataset._wired = "1";
            clearFilters.addEventListener("click", () => {
                document.querySelectorAll(".btl-toggle.active").forEach(btn => {
                    btn.classList.remove('active');
                    btn.style.background = "#fff";
                    btn.style.color = "#333";
                    btn.style.borderColor = "#ccc";
                });
                if (sortDropdownEl) sortDropdownEl.value = "rate";
                if (filterBox && filterBtn) {
                    filterBox.style.height = filterBox.scrollHeight + "px";
                    void filterBox.offsetHeight;
                    filterBox.style.height = "0px";
                    filterBox.style.padding = "0 12px";
                    filterBtn.textContent = "Filters";
                }
                applyFiltersAndSort();
            });
        }

        if (filterBtn && filterBox && !filterBtn.dataset._wired) {
            filterBtn.dataset._wired = "1";
            filterBtn.addEventListener("click", () => {
                const isClosed = filterBox.style.height === "0px" || !filterBox.style.height;
                if (isClosed) {
                    filterBox.style.padding = "12px";
