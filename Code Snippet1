        if (msr !== undefined && msr !== null && String(msr).trim() !== '') {
            const n = parseFloat(String(msr).replace(/[^0-9.\-]/g, ''));
            if (!isNaN(n)) return n;
        }
        const rf = product.rates_from ?? product.rates_from_display ?? product.rates_from_value;
        if (rf !== undefined && rf !== null && String(rf).trim() !== '') {
            const n = parseFloat(String(rf).replace(/[^0-9.\-]/g, ''));
            if (!isNaN(n)) return n;
        }
        return null;
    }

    // For monthly interest we MUST prefer rates_from specifically (user requested)
    function numericRateFromRatesFrom(product) {
