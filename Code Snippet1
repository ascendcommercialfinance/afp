    function isCF7Visible() {
        try {
            const forms = document.querySelectorAll('.wpcf7, .wpcf7-form, form.wpcf7-form');
            for (const el of forms) {
                if (!el) continue;
                const cs = window.getComputedStyle(el);
                if (!cs) continue;
                const visibleByStyle = cs.display !== 'none' && cs.visibility !== 'hidden' && parseFloat(cs.opacity || '1') > 0;
                const rect = el.getBoundingClientRect ? el.getBoundingClientRect() : null;
                const hasSize = rect ? (rect.width > 0 && rect.height > 0) : false;
                const inDOM = document.body.contains(el);
                if (inDOM && visibleByStyle && hasSize) return true;
            }
