<script>
let fullResults = [];
let eligibleResults = [];
let allResults = [];
let lastRenderedList = [];

// Pagination globals for Load more
let resultsOffset = 0;
const resultsPageSize = 10;

/* --- Restore the original global no-scroll behavior (same as your old code) ---
   This IIFE runs immediately and prevents any later script from auto-focusing
   or calling scrollIntoView and causing a jump. */
(function() {
    const origFocus = HTMLElement.prototype.focus;
    HTMLElement.prototype.focus = function(options) {
        if (options && typeof options === "object") {
            options.preventScroll = true;
        } else {
            options = { preventScroll: true };
        }
        try { origFocus.call(this, options); } catch(e) {}
    };
    Element.prototype.scrollIntoView = function() {
        // Fully block auto-scroll
    };
})();

document.addEventListener("DOMContentLoaded", function () {
    const onPortalPage = document.body.classList.contains("page-id-9549");
    if (!onPortalPage) return;

    // Guard flag: if set to true, observers will allow padding changes for a short time.
    window._allowPaddingChange = false;
    // Guard to indicate intentional hides (so back-to-results observer doesn't fight intended flows)
    if (typeof window._funderIntentionalHide === 'undefined') window._funderIntentionalHide = false;

    // Compare selection state (persist in sessionStorage so selections survive paging/filtering)
    if (!window._funder_compare_set) {
        const saved = sessionStorage.getItem('funder_compare_ids');
        try {
            window._funder_compare_set = new Set(saved ? JSON.parse(saved) : []);
        } catch (e) {
            window._funder_compare_set = new Set();
        }
    }

    // Selected product for CF7 (persist until submission)
    if (!window._funder_selected_product) {
        window._funder_selected_product = null;
    }

    let formJourneyStarted = false;
    let activeForm = document.querySelector("#forminator-module-10159");
    let scrollLockUntilStep = null;

    // Keep disabling Forminator scroll helpers (as before)
    if (window.ForminatorFront && window.ForminatorFront.scrollToTop) {
        window.ForminatorFront.scrollToTop = function() {};
    } else {
        const int = setInterval(() => {
            if (window.ForminatorFront && window.ForminatorFront.scrollToTop) {
                window.ForminatorFront.scrollToTop = function() {};
                clearInterval(int);
            }
        }, 50);
    }

    if (window.ForminatorFront && window.ForminatorFront.scrollToElement) {
        window.ForminatorFront.scrollToElement = function() {};
    } else {
        const int2 = setInterval(() => {
            if (window.ForminatorFront && window.ForminatorFront.scrollToElement) {
                window.ForminatorFront.scrollToElement = function() {};
                clearInterval(int2);
            }
        }, 50);
    }

    // MutationObserver to remove unwanted inline scroll-padding / padding-top changes
    (function preventInlinePaddingChanges() {
        const removeIfPresent = (el) => {
            if (!el || !el.style) return;
            try {
                if (!window._allowPaddingChange) {
                    if (el.style.scrollPaddingTop && el.style.scrollPaddingTop !== '') {
                        el.style.removeProperty('scroll-padding-top');
                    }
                    if (el.style.paddingTop && el.style.paddingTop !== '') {
                        el.style.removeProperty('padding-top');
                    }
                }
            } catch (e) {}
        };

        const observerCallback = (mutations) => {
            for (const m of mutations) {
                if (m.type === 'attributes' && m.attributeName === 'style') {
                    removeIfPresent(m.target);
                }
            }
        };

        const opts = { attributes: true, attributeFilter: ['style'], subtree: false };
        try {
            const htmlObserver = new MutationObserver(observerCallback);
            htmlObserver.observe(document.documentElement, opts);

            const bodyObserver = new MutationObserver(observerCallback);
            bodyObserver.observe(document.body, opts);

            // Clean any existing inline styles at startup
            removeIfPresent(document.documentElement);
            removeIfPresent(document.body);
        } catch (e) {
            setTimeout(() => {
                removeIfPresent(document.documentElement);
                removeIfPresent(document.body);
            }, 200);
        }
    })();

    function hideHeader() {
        const masthead = document.querySelector("#ct-masthead");
        const wrap = document.querySelector("#ct-header-wrap");
        const header = document.querySelector("#ct-header");
        if (masthead) masthead.style.setProperty("display", "none", "important");
        if (wrap) wrap.style.setProperty("display", "none", "important");
        if (header) header.style.setProperty("display", "none", "important");
        // intentionally do NOT set documentElement.scrollPaddingTop or body.paddingTop here
    }

    function showHeader() {
        const masthead = document.querySelector("#ct-masthead");
        const wrap = document.querySelector("#ct-header-wrap");
        const header = document.querySelector("#ct-header");
        if (masthead) masthead.style.removeProperty("display");
        if (wrap) wrap.style.removeProperty("display");
        if (header) header.style.removeProperty("display");
        // intentionally do NOT restore documentElement.scrollPaddingTop or body.paddingTop here
    }

    document.addEventListener("click", function(e) {
        if (e.target.id === "start-now-btn") {
            formJourneyStarted = true;
            if (window.innerWidth <= 1198) hideHeader();
        }
    });

    const observer = new MutationObserver(() => {
        const results = document.querySelector("#funder-results");
        if (results && results.style.display !== "none" && window.innerWidth <= 1198) {
            showHeader();
            observer.disconnect();
        }
    });

    observer.observe(document.body, {
        childList: true,
        subtree: true,
        attributes: true,
        attributeFilter: ["style"]
    });

    function enterHandler(e) {
        const key = e.key || e.keyCode;
        if (key !== "Enter" && key !== 13) return;
        const form = e.target.closest("form");
        if (!form) return;
        const submitBtn = form.querySelector(".forminator-button-submit:not([style*='display: none'])");
        const nextBtn = form.querySelector(".forminator-button-next:not([style*='display: none'])");
        if (submitBtn) { e.preventDefault(); submitBtn.click(); return; }
        if (nextBtn) { e.preventDefault(); nextBtn.click(); }
    }

    function enableEnterToContinue(form) {
        if (window.innerWidth > 1198) return;
        form.querySelectorAll("input, select, textarea").forEach(el => {
            el.removeEventListener("keydown", enterHandler, true);
            el.addEventListener("keydown", enterHandler, true);
        });
    }

    function forceTop() { window.scrollTo(0, 0); }

    function clearRadios(form) {
        if (!form) return;
        const radios = form.querySelectorAll("input[type='radio']");
        radios.forEach(r => {
            r.checked = false;
            const label = r.closest("label.forminator-radio");
            if (label) label.classList.remove("forminator-is_checked");
        });
    }

    function wireRadios(form) {
        if (!form) return;
        const nextBtn = form.querySelector(".forminator-button-next");
        if (!nextBtn) return;
        const radios = form.querySelectorAll("input[type='radio']");
        const visibleRadios = Array.from(radios).filter(r => r.offsetParent !== null);
        if (!visibleRadios.length) {
            nextBtn.style.display = "";
            return;
        }
        nextBtn.style.display = "none";
        visibleRadios.forEach(radio => {
            if (radio.dataset.autoWired === "1") return;
            radio.dataset.autoWired = "1";
            radio.addEventListener("click", (e) => {
                e.target.blur();
                if (radio.checked) {
                    radio.checked = false;
                    setTimeout(() => {
                        radio.checked = true;
                        radio.dispatchEvent(new Event("change", { bubbles: true }));
                    }, 0);
                }
            });
            radio.addEventListener("change", () => {
                if (!radio.checked) return;
                nextBtn.click();
                requestAnimationFrame(() => applyScrollLockIfNeeded());
            });
        });
    }

    function getCurrentStep(form) {
        if (!form) return null;
        const pages = form.querySelectorAll(".forminator-pagination");
        for (const page of pages) {
            const hidden = page.hidden || page.getAttribute("aria-hidden") === "true";
            const style = page.getAttribute("style") || "";
            const visible = !hidden && !style.includes("opacity: 0") && !style.includes("visibility: hidden");
            if (visible) {
                const step = parseInt(page.getAttribute("data-step"), 10);
                if (!isNaN(step)) return step;
            }
        }
        return null;
    }

    function applyScrollLockIfNeeded() {
        if (!activeForm) return;
        if (!formJourneyStarted) return;
        const step = getCurrentStep(activeForm);
        if (step === null) return;
        if (scrollLockUntilStep !== null && step <= scrollLockUntilStep) {
            window.scrollTo(0, 0);
        } else if (scrollLockUntilStep !== null && step > scrollLockUntilStep) {
            scrollLockUntilStep = null;
        }
    }

    const stepObserver = new MutationObserver(() => {
        if (!activeForm) return;
        wireRadios(activeForm);
        enableEnterToContinue(activeForm);
    });

    const routerContainer = document.getElementById("router-form");
    if (routerContainer) {
        stepObserver.observe(routerContainer, { childList: true, subtree: true });
    }

    function reattachObserverToForm(form) {
        try { stepObserver.disconnect(); } catch (e) {}
        if (!form) return;
        stepObserver.observe(form, { childList: true, subtree: true });
    }

    // showForm: temporarily allow padding changes and keep Forminator suppression while switching
    function showForm(containerId, moduleId) {
        // Temporarily allow padding changes while switching (short window)
        window._allowPaddingChange = true;
        setTimeout(() => { window._allowPaddingChange = false; }, 520);

        // Also keep Forminator suppressed for the switch
        if (window.ForminatorFront && window.ForminatorFront.scrollToTop) {
            // already suppressed above
        }

        document.getElementById("router-form").style.display = "none";
        document.getElementById("btl-form").style.display = "none";
        document.getElementById("commercial-form").style.display = "none";
        document.getElementById("coming-soon").style.display = "none";
        const container = document.getElementById(containerId);
        if (container) container.style.display = "block";
        activeForm = container ? container.querySelector(`#${moduleId}`) : null;
        clearRadios(activeForm);
        scrollLockUntilStep = 1;
        setTimeout(() => {
            wireRadios(activeForm);
            enableEnterToContinue(activeForm);
            applyScrollLockIfNeeded();
        }, 150);
        reattachObserverToForm(activeForm);
    }

    document.addEventListener("change", function (e) {
        const routerVisible = document.getElementById("router-form") && document.getElementById("router-form").offsetParent !== null;
        if (!routerVisible) return;
        if (!e.target.matches("input[type='radio']")) return;
        const val = e.target.value;
        if (val === "btlmortgage") { showForm("btl-form", "forminator-module-9548"); return; }
        if (val === "commmortgage") { showForm("commercial-form", "forminator-module-10157"); return; }
        document.getElementById("router-form").style.display = "none";
        document.getElementById("coming-soon").style.display = "block";
        clearRadios(document.querySelector("#forminator-module-10159"));
        activeForm = null;
        scrollLockUntilStep = null;
        // do not forceTop here; keep natural position
    });

    let handled = false;
    const successObs = new MutationObserver(() => {
        if (!activeForm) return;
        const success = activeForm.querySelector(".forminator-response-message:not([aria-hidden='true'])");
        if (success && !handled) {
            handled = true;
            requestAnimationFrame(() => {
                const formData = {};
                const fields = activeForm.querySelectorAll("[name]");
                fields.forEach(field => {
                    const name = field.name.replace("[]", "");
                    if (field.type === "radio") {
                        const label = field.closest("label.forminator-radio");
                        if (!label || !label.classList.contains("forminator-is_checked")) return;
                    }
                    let question = "";
                    const wrapper = field.closest(".forminator-field");
                    if (wrapper) {
                        const qLabel = wrapper.querySelector(".forminator-label");
                        if (qLabel) question = qLabel.innerText.trim();
                    }
                    if (!formData[name]) formData[name] = { question: question, values: [] };
                    if (!field.value) return;
                    formData[name].values.push(field.value.trim());
                });

                // persist parsed answers so displayResults can pre-activate relevant toggles
                window._funder_form_answers = formData;

                fetch("/?funder_match=1", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(formData)
                })
                .then(res => res.json())
                .then(data => {
                    displayResults(data);
                });
            });
        }
    });

    successObs.observe(document.body, { childList: true, subtree: true });

    /* -------------------------
       DISPLAY + FILTERING LOGIC
    ------------------------- */

    // Normaliser used for dedupe and intersection
    function norm(s) {
        if (s === undefined || s === null) return '';
        return String(s)
            .replace(/\u00A0/g, ' ')
            .replace(/[^\w\s\.\-\/%£€\d]/g, '')
            .replace(/[\u2010-\u2015]/g, '-')
            .replace(/\s+/g, ' ')
            .trim()
            .toLowerCase();
    }

    function preactivateRateAndPropToggles(answers) {
        if (!answers || typeof answers !== 'object') return;
        function firstValue(v) {
            if (v === undefined || v === null) return '';
            if (typeof v === 'string') return v;
            if (Array.isArray(v) && v.length) return v[0];
            if (typeof v === 'object' && Array.isArray(v.values) && v.values.length) return v.values[0];
            return String(v);
        }
        function activate(toggleKey, value) {
            if (!value) return;
            const sel = `.btl-toggle[data-toggle="${toggleKey}"][data-value="${String(value).toLowerCase()}"]`;
            const btn = document.querySelector(sel);
            if (!btn) return;
            if (!btn.classList.contains('active')) {
                btn.classList.add('active');
                btn.style.background = "#149580";
                btn.style.color = "white";
                btn.style.borderColor = "#149580";
            }
        }
        const rawRate = firstValue(answers['radio-21'] || answers['rate_type'] || answers['radio-6'] || '');
        const rateAns = String(rawRate || '').toLowerCase();
        if (rateAns) {
            if (rateAns.includes('fix')) activate('rate_type', 'fixed');
            if (rateAns.includes('var') || rateAns.includes('track') || rateAns.includes('tracker') || rateAns.includes('discount')) activate('rate_type', 'variable');
        }
        const hmoRaw = firstValue(answers['radio-18'] || answers['hmo'] || '');
        const mufbRaw = firstValue(answers['radio-22'] || answers['mufb'] || '');
        const holidayRaw = firstValue(answers['radio-23'] || answers['holiday'] || '');
        const hmo = String(hmoRaw || '').toLowerCase();
        const mufb = String(mufbRaw || '').toLowerCase();
        const holiday = String(holidayRaw || '').toLowerCase();
        if (hmo === 'yes' || hmo === 'hmo') activate('prop_type', 'hmo');
        if (mufb === 'yes' || mufb === 'mufb') activate('prop_type', 'mufb');
        if (holiday === 'yes' || holiday === 'holiday') activate('prop_type', 'holiday');
    }

    function displayResults(data) {
        window.lastResults = Array.isArray(data.matched_results) ? data.matched_results.slice() : [];
        console.log("RESULT SAMPLE:", (data.matched_results || [])[0]);

        const container = document.getElementById("funder-results");
        const content = document.getElementById("funder-results-content");
        if (!container || !content) return;

        fullResults = Array.isArray(data.all_results) ? data.all_results.slice() : [];
        eligibleResults = Array.isArray(data.matched_results) ? data.matched_results.slice() : [];
        allResults = Array.isArray(data.all_results) ? data.all_results.slice() : [];

        let html = "";

        html += `
            <div style="
                background:#e6f7ec;
                border:1px solid #14958055;
                padding:28px 20px;
                border-radius:8px;
                margin-top:14px;
                margin-bottom:20px;
                font-size:16px;
                color:#149580;
                font-weight:600;
                text-align: center;
            ">
                <div>🎉 Congratulations!</div>
                <div>We've found lenders you're eligible for you. Review your matched options below.</div>
            </div>
        `;

        if (!data || !data.matched_results || data.matched_results.length === 0) {
            content.innerHTML = `
                <div style="
                    background:#fff8e6;
                    border:1px solid #e6c77c;
                    padding:18px 20px;
                    border-radius:8px;
                    margin-bottom:20px;
                    margin-top:14px;
                    font-size:16px;
                    color:#8a6d1d;
                    font-weight:600;
                    text-align:center;
                ">
                    <div>We haven’t found any eligible options on our portal this time.</div>
                    <div>One of our team will be happy to run a full market search for you.</div>
                </div>

                <button id="no-results-apply-btn"
                    style="
                        background:#149580;
                        color:white;
                        border-radius:6px;
                        font-size:12px;
                        font-weight:600;
                        line-height:36px;
                        cursor:pointer;
                        margin-top:10px;
                        display: block;
                        margin: 20px auto 0 auto;
                        text-align: center;
                    ">
                    Request Call
                </button>
                <div id="restart-search-link"
                     style="
                        text-align:center;
                        margin-top:16px;
                        font-size:14px;
                        color:#149580;
                        cursor:pointer;
                        font-weight:500;
                     ">
                    Restart Search
                </div>
            `;
            container.style.display = "block";

            if (activeForm) {
                const productWrapper = activeForm.closest("div[id$='-form']");
                if (productWrapper) productWrapper.style.display = "none";
                const elementorWrapper = activeForm.closest(".elementor-widget-container");
                if (elementorWrapper) elementorWrapper.style.display = "none";
                const widget = activeForm.closest(".elementor-element.elementor-widget-html");
                if (widget) widget.style.display = "none";
                activeForm.style.display = "none";
                const pagination = activeForm.querySelector(".forminator-pagination");
                if (pagination) pagination.style.display = "none";
                clearRadios(activeForm);
            }

            const noResultsApplyBtn = document.getElementById("no-results-apply-btn");
            const restartSearch = document.getElementById("restart-search-link");
            if (restartSearch) restartSearch.addEventListener("click", () => {
                // clear compare selections before reload
                try { sessionStorage.removeItem('funder_compare_ids'); } catch(e) {}
                try { sessionStorage.removeItem('funder_selected_product'); } catch(e) {}
                if (window._funder_compare_set) window._funder_compare_set = new Set();
                updateCompareUI();
                window.location.reload();
            });
            if (noResultsApplyBtn) {
                noResultsApplyBtn.addEventListener("click", () => {
