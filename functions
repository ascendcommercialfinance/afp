/* ---------------------------------------------------------
   GOOGLE SHEETS API READER
--------------------------------------------------------- */
function get_google_sheet_data($product_type) {
    $sheet_id = '1dlRtldJD4MxtL4gLqy47fB9U09UZTr03jeYBB4gfqns';
    $api_key  = 'AIzaSyDths-33jmqQ63UJLCe2LFTfemQuIQ38dI';

    $sheet_name = $product_type;
    $url        = "https://sheets.googleapis.com/v4/spreadsheets/$sheet_id/values/$sheet_name?key=$api_key";

    $response = wp_remote_get($url, ['timeout' => 15]);
    if (is_wp_error($response)) {
        return false;
    }

    $body = json_decode(wp_remote_retrieve_body($response), true);
    if (!isset($body['values']) || !is_array($body['values'])) {
        return false;
    }

    $rows    = [];
    $headers = $body['values'][0];

    foreach ($body['values'] as $index => $row) {
        if ($index === 0) {
            continue;
        }
        while (count($row) < count($headers)) {
            $row[] = '';
        }
        $rows[] = array_combine($headers, $row);
    }

    return $rows;
}

